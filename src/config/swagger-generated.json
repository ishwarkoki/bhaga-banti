                    "type": "number",
                    "minimum": 0
                  },
                  "method": {
                    "type": "string",
                    "enum": [
                      "cash",
                      "upi",
                      "bank_transfer",
                      "other"
                    ]
                  },
                  "notes": {
                    "type": "string"
                  }
                }
              }
            }
