{
  "name": "bhaga-banti",
  "version": "1.0.0",
  "description": "A Splitwise clone for sharing expenses with friends - written in Odia as 'bhaga-banti' (sharing-dividing)",
  "main": "dist/app.js",
  "type": "module",
  "packageManager": "pnpm@10.18.1",
  "scripts": {
    "dev": "./scripts/dev-server.sh",
    "dev:watch": "tsx watch src/app.ts",
    "build": "tsx scripts/generate-swagger.ts && tsc",
    "start": "node dist/app.js",
    "deploy": "pnpm build && pnpm db:push && pnpm auth:generate",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "auth:generate": "npx @better-auth/cli@latest generate",
    "auth:migrate": "npx @better-auth/cli@latest migrate",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test && pnpm build"
  },
  "keywords": [
    "splitwise",
    "expense-sharing",
    "bhaga-banti",
    "finance",
    "nodejs",
    "express",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "better-auth": "^1.6.9",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.0",
    "helmet": "^8.1.0",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
